{
  "name": "treats",
  "version": "0.1.0",
  "private": true,
  "description": "Treats — a cute desktop pet that helps you train your AI coding helper. Pet it (or say /treats:good) when it does great work, scold it when it slips, and it actually does better next time. Pick your animal; each project keeps its own score.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "treats": "packages/core/bin/treats.js"
  },
  "scripts": {
    "treats": "node packages/core/bin/treats.js",
    "install-all": "node packages/core/bin/treats.js install",
    "install-hooks": "node packages/core/bin/treats.js install-hooks",
    "install-commands": "node packages/core/bin/treats.js install-commands",
    "install-skills": "node packages/core/bin/treats.js install-skills",
    "install-statusline": "node packages/core/bin/treats.js install-statusline",
    "install-schedule": "node scripts/install-schedule.js",
    "gen-sounds": "node scripts/gen-sounds.js",
    "gen-icons": "node scripts/gen-icons.js",
    "gen-assets": "node scripts/gen-sounds.js && node scripts/gen-icons.js",
    "demo": "bash scripts/demo.sh",
    "pet": "env -u ELECTRON_RUN_AS_NODE electron packages/overlay",
    "overlay": "env -u ELECTRON_RUN_AS_NODE electron packages/overlay"
  },
  "license": "MIT"
}
